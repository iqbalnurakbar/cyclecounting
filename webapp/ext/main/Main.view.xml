<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    controllerName="cyclecounting.ext.main.Main"
>
    <Page
        id="idMainPage"
        title="{i18n>MainTitle}"
        titleAlignment="Center"
    >
        <content>
            <f:Form
                id="idMainForm"
                editable="true"
                class="sapUiMediumMargin"
            >
                <f:layout>
                    <f:ResponsiveGridLayout
                        id="idResponsiveGridLayout"
                        labelSpanXL="5"
                        labelSpanL="5"
                        labelSpanM="5"
                        emptySpanXL="1"
                        emptySpanL="1"
                        emptySpanM="1"
                        columnsXL="3"
                        columnsL="3"
                        columnsM="2"
                        class="sapUiMediumMargin"
                    />
                </f:layout>
                <f:formContainers>
                    <!-- Column 1 -->
                    <f:FormContainer id="idColumn1FormContainer">
                        <f:formElements>
                            <f:FormElement
                                id="idCountedUnitFormElement"
                                label="{i18n>CountedUnit}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idCountedUnitInput"
                                        type="Number"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idMaterialFormElement"
                                label="{i18n>Material}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idMaterialInput"
                                        maxLength="40"
                                        change="onInputMaterialChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idDescriptionFormElement"
                                label="{i18n>Description}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idDescriptionInput"
                                        maxLength="40"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idBatchFormElement"
                                label="{i18n>Batch}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idBatchInput"
                                        maxLength="10"
                                        change="onInputForSAPQtyChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idStockCategoryFormElement"
                                label="{i18n>StockCategory}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idStockCategoryInput"
                                        maxLength="1"
                                        change="onInputForSAPQtyChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idSpecialStockIndicatorFormElement"
                                label="{i18n>SpecialStockIndicator}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idSpecialStockIndicatorInput"
                                        maxLength="1"
                                        change="onInputForSAPQtyChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idSpecialStockNumberFormElement"
                                label="{i18n>SpecialStockNumber}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idSpecialStockNumberInput"
                                        maxLength="16"
                                        change="onInputForSAPQtyChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idSAPDifferenceFormElement"
                                label="{i18n>SAPDifference}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idSAPDifferenceInput"
                                        editable="false"
                                        type="Number"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idGroupIDFormElement"
                                label="{i18n>GroupID}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idGroupIDInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idRemarkFormElement"
                                label="{i18n>Remark}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idRemarkInput"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>
                    <!-- Column 2 -->
                    <f:FormContainer id="idColumn2FormContainer">
                        <f:formElements>
                            <f:FormElement
                                id="idTotalCountedFormElement"
                                label="{i18n>TotalCounted}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idTotalCountedInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idStateFormElement"
                                label="{i18n>State}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idStateInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idDescription2FormElement"
                                label="{i18n>Description2}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idDescription2Input"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idScheduleFormElement"
                                label="{i18n>Schedule}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idScheduleInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idDifferenceQtyFormElement"
                                label="{i18n>DifferenceQty}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idDifferenceQtyInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idRequestDateFormElement"
                                label="{i18n>RequestDate}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <DatePicker
                                        id="idRequestDatePicker"
                                        displayFormat="yyyy/MM/dd"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idRequestorFormElement"
                                label="{i18n>Requestor}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idRequestorInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idLastModifyFormElement"
                                label="{i18n>LastModify}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idLastModifyInput"
                                        editable="false"
                                        maxLength="12"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idToleranceFormElement"
                                label="{i18n>Tolerance}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idToleranceInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idOrderTypeFormElement"
                                label="{i18n>OrderType}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idOrderTypeInput"
                                        maxLength="5"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>
                    <!-- Column 3 -->
                    <f:FormContainer id="idColumn3FormContainer">
                        <f:formElements>
                            <f:FormElement
                                id="idLocationFormElement"
                                label="{i18n>Location}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <ComboBox
                                        id="idLocationComboBox"
                                        width="100%"
                                        showSecondaryValues="true"
                                        change="onLocationChange"
                                        selectionChange="onLocationChange"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idProblemFormElement"
                                label="{i18n>Problem}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <ComboBox
                                        id="idProblemVhComboBox"
                                        width="100%"
                                        items="{/problem_vh}"
                                        showSecondaryValues="true"
                                    >
                                        <core:ListItem
                                            id="idZrsnCodeListItem"
                                            key="{ZrsnCode}"
                                            text="{ZrsnCode}"
                                            additionalText="{= ${ZdefTy} + ' - ' + ${ZrsnDesc} }"
                                        />
                                    </ComboBox>
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idSiteFormElement"
                                label="{i18n>Site}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idSiteInput"
                                        maxLength="4"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idSAPQtyFormElement"
                                label="{i18n>SAPQty}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idSAPQtyInput"
                                        editable="false"
                                        type="Number"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idDifferenceValueFormElement"
                                label="{i18n>DifferenceValue}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idDifferenceValueInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idPartTypeFormElement"
                                label="{i18n>PartType}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idPartTypeInput"
                                        editable="false"
                                        maxLength="4"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idFulfilmentDateFormElement"
                                label="{i18n>FulfilmentDate}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <DatePicker
                                        id="idFulfilmentDatePicker"
                                        displayFormat="yyyy/MM/dd"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idDeadlineFormElement"
                                label="{i18n>Deadline}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <DatePicker
                                        id="idDeadlineDatePicker"
                                        displayFormat="yyyy/MM/dd"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idCOGIFormElement"
                                label="{i18n>COGI}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idCOGIInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>
                </f:formContainers>
            </f:Form>
            <!-- Buttons Centered Below Form -->
            <HBox
                id="idButtonsHBox"
                width="100%"
                justifyContent="Center"
                class="sapUiLargeMarginTop"
            >
                <items>
                    <Button
                        id="idJumpToCountingButton"
                        type="Emphasized"
                        text="{i18n>Overplus}"
                        class="sapUiSmallMargin"
                        press="onButtonJumpToCountingPress"
                        tooltip="{i18n>OverplusTooltip}"
                    />
                    <Button
                        id="idSaveWithoutSubmitButton"
                        type="Emphasized"
                        text="{i18n>Next}"
                        class="sapUiSmallMargin"
                        press="onButtonSaveWithoutSubmitPress"
                        tooltip="{i18n>NextTooltip}"
                    />
                    <Button
                        id="idSaveAndSubmitButton"
                        type="Emphasized"
                        text="{i18n>Save}"
                        class="sapUiSmallMargin"
                        press="onButtonSaveAndSubmitPress"
                        tooltip="{i18n>SaveTooltip}"
                    />
                    <Button
                        id="idSumButton"
                        type="Emphasized"
                        text="{i18n>Sum}"
                        class="sapUiSmallMargin"
                        press="onButtonSumPress"
                        tooltip="{i18n>SumTooltip}"
                    />
                    <Button
                        id="idDeleteButton"
                        type="Reject"
                        text="{i18n>Delete}"
                        class="sapUiSmallMargin"
                        press="onButtonClearDataPress"
                    />
                    <Button
                        id="idViewMaterialButton"
                        type="Emphasized"
                        text="{i18n>ViewMaterial}"
                        class="sapUiSmallMargin"
                        press="onButtonViewMaterialPress"
                    />
                </items>
            </HBox>
        </content>
    </Page>
</mvc:View>
